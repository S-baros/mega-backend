# Banco de Dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/mega_db"

# JWT - chave secreta para gerar tokens de autenticação (troque por algo aleatório)
JWT_SECRET="mega_jr_secret_key_troque_isso_em_producao"
JWT_EXPIRES_IN="7d"

# Porta do servidor
PORT=3000
